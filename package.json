{
  "name": "web-player",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e:runtime": "vitest run tests/runtime-gate.e2e.spec.ts --environment happy-dom --reporter=verbose",
    "test:e2e:runtime:gate": "npm run test:e2e:runtime && npm run test:e2e:runtime"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.6",
    "lodash": "^4.17.21",
    "tailwindcss": "^4.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22.15.17",
    "eslint": "^9.25.0",
    "globals": "^16.0.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.2"
  }
}
